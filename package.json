{
  "name": "t20-pdf-exporter",
  "version": "0.1.0",
  "description": "Foundry VTT module to export Tormenta 20 character sheets to PDF.",
  "type": "module",
  "private": true,
  "author": {
    "name": "Yuri Lupalina",
    "email": "yuri@lupalina.com.br"
  },
  "license": "MIT",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch --mode development",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,scss,css,hbs,json}\""
  },
  "devDependencies": {
    "fvtt-types": "github:League-of-Foundry-Developers/foundry-vtt-types#main",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
